#theme = "3024 Night"
#theme = "Abernathy"
theme = "Cyberpunk"
#theme = "Synthwave"
#theme = "Builtin Pastel Dark"

font-family = "Inconsolata Nerd Font"
font-size = 14

scrollback-limit = 10000000000

# Show a link preview at the bottom of the window
link-previews = true

# Shell integration
shell-integration-features = ssh-terminfo,ssh-env

# Default cursor style is a blinking line.
# To get a static block, add no-cursor to shell-integration-features and uncomment:
# cursor-style = block
# cursor-style-blink = false

# Make the mouse cursor disappear when typing
mouse-hide-while-typing = true

# Open new windows in a predictable place
window-inherit-working-directory = false

# Open new windows at the same size, regardless of the size of the last window
window-inherit-font-size = false

# shift + navkeys to scroll
# apparently ghostty doesn't support the Apple Terminal behavior I prefer
# where it scrolls the terminal in normal mode
# and sends the key to the program in alternate mode
keybind = shift+page_up=scroll_page_up
keybind = shift+page_down=scroll_page_down
keybind = shift+home=scroll_to_top
keybind = shift+end=scroll_to_bottom

# Don't save and restore window state across launches.
# On macOS you also want to do this:
#   defaults write com.mitchellh.ghostty ApplePersistenceIgnoreState -bool true
window-save-state = never

# Just open terminals with a default size, not whatever it thinks based on the last 47 terminals I resized
window-height = 25
window-width = 80

config-file = ?config.local

