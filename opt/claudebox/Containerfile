FROM debian:stable-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        curl \
        file \
        git \
        gzip \
        iputils-ping \
        jq \
        nftables \
        nodejs \
        procps \
        python3 \
        ruby \
        squid \
        zsh \
    && rm -rf /var/lib/apt/lists/*

COPY entrypoint.sh /usr/local/bin/claudebox-entrypoint
COPY netblocked /usr/local/bin/netblocked
COPY squid.conf netwhitelist-default.txt /etc/claudebox/

RUN useradd -m -u 1000 -s /bin/zsh claude \
    && mkdir -p /home/linuxbrew \
    && chown claude:claude /home/linuxbrew

USER claude

ENV HOMEBREW_PREFIX=/home/linuxbrew/.linuxbrew
ENV PATH="$HOMEBREW_PREFIX/bin:$HOMEBREW_PREFIX/sbin:$PATH"

RUN NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

RUN brew install --cask claude-code codex

WORKDIR /src

ENTRYPOINT ["/usr/local/bin/claudebox-entrypoint"]
