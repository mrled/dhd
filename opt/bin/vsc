#!/bin/sh
set -eu

usage() {
    cat <<ENDUSAGE
Usage: $0 [-h] [-d] [-U USERNAME] [-H HOSTNAME] [PATH]

Open a file or directory in VS Code.

If not run over SSH, runs 'code PATH'.
If run over SSH, emits a clickable vscode:// URI to open the path remotely.
Works inside and outside of tmux.

ARGUMENTS
    -h | --help:        Print help and exit
    -d | --debug:       Show debug messages
    -U USERNAME:        Username for the SSH remote URL (default: current user).
                        Pass empty string to omit user@ from the URL.
    -H HOSTNAME:        Hostname for the SSH remote URL (default: system hostname)
    PATH:               File or directory to open (default: current directory)
ENDUSAGE
}

# Emit an OSC 8 hyperlink.
# For this to work in tmux, requires tmux 3.4+ with
#   set -g allow-passthrough on
#   set -as terminal-features ',xterm-ghostty:hyperlinks'   # replace xterm-ghostty with your $TERM
osc8_link() {
    printf '\033]8;;%s\033\\%s\033]8;;\033\\\n' "$1" "$2"
}

patharg="."
username="$(id -un)"
hostname_arg=""
while test $# -gt 0; do
    case "$1" in
        -h | --help ) usage; exit 0 ;;
        -d | --debug ) set -x; shift ;;
        -U ) username="$2"; shift 2 ;;
        -H ) hostname_arg="$2"; shift 2 ;;
        * )
            if test "$patharg" != "."; then
                echo "$0: too many arguments: $1" >&2
                usage >&2
                exit 1
            fi
            patharg="$1"
            shift
            ;;
    esac
done

if test -d "$patharg"; then
    cd "$patharg"
    abspath="$(pwd -P)"
else
    cd "$(dirname "$patharg")"
    abspath="$(pwd -P)/$(basename "$patharg")"
fi

if test "${SSH_CONNECTION:-}" || test "${SSH_CLIENT:-}"; then
    host="${hostname_arg:-$(hostname)}"
    if test -n "$username"; then
        userprefix="${username}@"
    else
        userprefix=""
    fi
    uri="vscode://vscode-remote/ssh-remote+${userprefix}${host}${abspath}?windowId=_blank"
    osc8_link "$uri" "$uri"
else
    code --new-window "$abspath"
fi
