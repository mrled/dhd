#!/bin/bash
set -euo pipefail

usage() {
    cat >&2 <<EOF
Usage: vt [-o] [SESSION]
  -o  Outer mode: use M-t prefix config; SESSION defaults to 'outer'
Without -o, SESSION is required.
EOF
    exit 1
}

outer=0
while getopts "o" opt; do
    case "$opt" in
        o) outer=1 ;;
        *) usage ;;
    esac
done
shift $((OPTIND - 1))

if [ "$outer" -eq 1 ]; then
    session="${1:-outer}"
    # -L outer uses a separate server socket so -f actually takes effect
    exec tmux -L outer -f ~/.dhd/hbase/.tmux.outer.conf new-session -A -s "$session"
else
    [ $# -lt 1 ] && usage
    session="$1"
    if [ -n "${TMUX:-}" ]; then
        # Rename the outer tmux window to match the inner session name.
        # $TMUX is "socket_path,server_pid,session_id"; extract the socket path.
        outer_socket="${TMUX%%,*}"
        tmux -S "$outer_socket" rename-window "$session"
    fi
    unset TMUX
    exec tmux -f ~/.dhd/hbase/.tmux.conf new-session -A -s "$session"
fi
