#!/usr/bin/env python3
"""claudebox2: containerized Claude Code runner with per-project overrides."""

import argparse
import hashlib
import os
import shutil
import subprocess
import sys
from dataclasses import dataclass
from typing import NoReturn


def die(msg: str) -> NoReturn:
    print(f"claudebox2: {msg}", file=sys.stderr)
    sys.exit(1)


def find_container_runtime() -> str:
    override = os.environ.get("CLAUDEBOX_CONTAINER_RUNTIME")
    if override:
        return override
    for rt in ("docker", "podman"):
        if shutil.which(rt):
            return rt
    die(
        "no container runtime found (tried docker, podman); set CLAUDEBOX_CONTAINER_RUNTIME"
    )


def find_git_root() -> str | None:
    try:
        result = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True,
            text=True,
            check=True,
        )
        return result.stdout.strip()
    except (subprocess.CalledProcessError, FileNotFoundError):
        return None


def find_claudebox_dir() -> str | None:
    """Return first .claudebox/ found in PWD then git root, or None."""
    candidates = [os.getcwd()]
    git_root = find_git_root()
    if git_root and os.path.realpath(git_root) != os.path.realpath(os.getcwd()):
        candidates.append(git_root)
    for base in candidates:
        d = os.path.join(base, ".claudebox")
        if os.path.isdir(d):
            return os.path.realpath(d)
    return None


def sha256_short(s: str) -> str:
    return hashlib.sha256(s.encode()).hexdigest()[:16]


def sha256_file_short(path: str) -> str:
    h = hashlib.sha256()
    with open(path, "rb") as f:
        h.update(f.read())
    return h.hexdigest()[:16]


def script_repo_root() -> str:
    """Derive repo root from this script's location: opt/bin/claudebox2 -> repo root."""
    return os.path.dirname(os.path.dirname(os.path.dirname(os.path.realpath(__file__))))


def _parse_lines(path: str) -> list[str]:
    with open(path) as f:
        return [l.strip() for l in f if l.strip() and not l.strip().startswith("#")]


def _resolve_mounts(lines: list[str], claudebox_parent: str) -> list[str]:
    result = []
    for line in lines:
        parts = line.split(":", 2)
        host = parts[0]
        if not os.path.isabs(host) and not host.startswith("~"):
            host = os.path.join(claudebox_parent, host)
        else:
            host = os.path.expanduser(host)
        result.append(":".join([host] + parts[1:]))
    return result


@dataclass
class Config:
    homedir: str
    containerfile: str
    build_context: str
    build_override: str | None
    run_override: str | None
    tag: str
    git_root: str | None
    extra_env: list[str]
    extra_mounts: list[str]
    host_path: str
    proj_hash: str


def resolve_config(claudebox_dir: str | None, git_root: str | None) -> Config:
    repo_root = script_repo_root()
    repo_cf = os.path.join(repo_root, "opt", "claudebox", "Containerfile")
    user_cf = os.path.expanduser("~/.config/claudebox/Containerfile.default")

    if os.path.isfile(user_cf):
        default_cf = user_cf
    elif os.path.isfile(repo_cf):
        default_cf = repo_cf
    else:
        die(f"default Containerfile not found at {user_cf} or {repo_cf}")

    if claudebox_dir:
        hash_input = claudebox_dir
        host_path = os.path.dirname(claudebox_dir)
    elif git_root:
        hash_input = os.path.realpath(git_root)
        host_path = hash_input
    else:
        hash_input = os.path.realpath(os.getcwd())
        host_path = hash_input
    proj_hash = sha256_short(hash_input)

    cf_override: str | None = None
    build_override: str | None = None
    run_override: str | None = None
    tag_override: str | None = None

    if claudebox_dir:
        p = os.path.join(claudebox_dir, "Containerfile")
        cf_override = p if os.path.isfile(p) else None
        p = os.path.join(claudebox_dir, "build.sh")
        build_override = p if os.path.isfile(p) else None
        p = os.path.join(claudebox_dir, "run.sh")
        run_override = p if os.path.isfile(p) else None
        p = os.path.join(claudebox_dir, "tag.txt")
        if os.path.isfile(p):
            with open(p) as f:
                tag_override = f.read().strip()

    extra_env: list[str] = []
    extra_mounts: list[str] = []
    if claudebox_dir:
        claudebox_parent = os.path.dirname(claudebox_dir)
        p = os.path.join(claudebox_dir, "env")
        if os.path.isfile(p):
            extra_env = _parse_lines(p)
        p = os.path.join(claudebox_dir, "mounts")
        if os.path.isfile(p):
            extra_mounts = _resolve_mounts(_parse_lines(p), claudebox_parent)

    homedir = os.path.expanduser(f"~/.local/state/claudebox/{proj_hash}")
    containerfile = cf_override or default_cf

    if tag_override:
        tag = tag_override
    elif cf_override or build_override:
        tag = f"claudebox-{proj_hash}"
    else:
        tag = f"claudebox-{sha256_file_short(containerfile)}"

    return Config(
        homedir=homedir,
        containerfile=containerfile,
        build_context=os.path.join(repo_root, "opt", "claudebox"),
        build_override=build_override,
        run_override=run_override,
        tag=tag,
        git_root=git_root,
        extra_env=extra_env,
        extra_mounts=extra_mounts,
        host_path=host_path,
        proj_hash=proj_hash,
    )


def image_exists(runtime: str, tag: str) -> bool:
    result = subprocess.run(
        [runtime, "image", "inspect", tag],
        capture_output=True,
    )
    return result.returncode == 0


def podman_is_rootless(runtime: str) -> bool:
    """Whether the connected Podman engine runs rootless. Defaults to False
    (rootful) if detection fails, since the rootful path (run as UID 0) also
    works under rootless."""
    result = subprocess.run(
        [runtime, "info", "--format", "{{.Host.Security.Rootless}}"],
        capture_output=True,
        text=True,
    )
    return result.stdout.strip() == "true"


def build_image(
    config: Config, runtime: str, extra_args: list[str] | None = None, force: bool = False
) -> None:
    args = extra_args or []
    if config.build_override:
        env = os.environ.copy()
        if force:
            env["CLAUDEBOX_FORCE"] = "1"
        subprocess.run([config.build_override] + args, check=True, env=env)
        return
    force_args = ["--no-cache"] if force else []
    subprocess.run(
        [
            runtime,
            "build",
            "--progress=plain",
            "--tag",
            config.tag,
            "--file",
            config.containerfile,
            config.build_context,
        ]
        + force_args
        + args,
        check=True,
    )


def cmd_hash(directory: str, literal: bool) -> None:
    if literal:
        directory = os.path.abspath(directory)
    else:
        directory = os.path.realpath(directory)
    print(sha256_short(directory))


def resolve_container_cmd(cmd_args: list[str]) -> list[str]:
    """Expand shorthand CMD tokens into their full container command."""
    if not cmd_args or cmd_args[0] == "claude":
        return ["claude", "--dangerously-skip-permissions"] + cmd_args[1:]
    if cmd_args[0] == "codex":
        return ["codex", "--dangerously-bypass-approvals-and-sandbox"] + cmd_args[1:]
    return cmd_args


def ensure_statedir(config: Config) -> None:
    """Create the state dir and keep hostpath.txt correct."""
    os.makedirs(config.homedir, exist_ok=True)
    hostpath_file = os.path.join(config.homedir, "hostpath.txt")
    if os.path.exists(hostpath_file):
        with open(hostpath_file) as f:
            recorded = f.read().strip()
        if recorded != config.host_path:
            print(
                f"claudebox2: warning: {hostpath_file} contains '{recorded}' but expected '{config.host_path}'; fixing",
                file=sys.stderr,
            )
            with open(hostpath_file, "w") as f:
                f.write(config.host_path + "\n")
    else:
        with open(hostpath_file, "w") as f:
            f.write(config.host_path + "\n")


def cmd_statedir(config: Config) -> None:
    ensure_statedir(config)
    print(f"Shortened hash of {config.host_path} is {config.proj_hash}", file=sys.stderr)
    print(config.homedir)


def _container_name(path: str) -> str:
    """Return a Docker-safe container name from the basename of path plus a 4-char random suffix."""
    import re
    name = os.path.basename(path.rstrip("/")) or "claudebox"
    name = re.sub(r"[^a-zA-Z0-9_.-]", "_", name)
    if not name[0].isalnum():
        name = "c" + name
    suffix = os.urandom(2).hex()
    return f"{name}-{suffix}"


def _volume_opt(src: str, dst: str, opts: list[str]) -> str:
    """Build a `src:dst[:opt1,opt2,...]` volume spec, dropping empty options."""
    spec = f"{src}:{dst}"
    present = [o for o in opts if o]
    if present:
        spec += ":" + ",".join(present)
    return spec


def check_rootless_traversable(path: str) -> None:
    """Under rootless Podman, crun prepares the nested .git bind mount as
    container-root and relies on CAP_DAC_OVERRIDE to traverse the project root --
    but only over a dir whose uid *and* gid are both mapped into the container.
    The macOS VM maps the user's uid and the VM's primary gid (core), not the
    dir's macOS group (usually staff/20), so a 0700 project root is untraversable;
    o+x on the root fixes it while leaving the contents owner-only.

    On Linux rootless the user's own primary gid is mapped, so a dir owned by that
    gid works without o+x -- skip the check there.
    """
    st = os.stat(path)
    if sys.platform != "darwin" and st.st_gid == os.getgid():
        return
    if not st.st_mode & 0o001:
        die(
            f"rootless Podman needs the project root traversable by the container "
            f"user, but '{path}' lacks o+x (other-execute). Fix with:\n"
            f"    chmod o+x {path}\n"
            f"This leaves the directory's contents owner-only."
        )


def cmd_run(config: Config, runtime: str, cmd_args: list[str]) -> NoReturn:
    if config.run_override:
        os.execv(config.run_override, [config.run_override] + cmd_args)

    if not image_exists(runtime, config.tag):
        build_image(config, runtime)

    ensure_statedir(config)

    # Pre-create parent dirs for mounts targeting /home/claude/... so Docker can
    # set up the mountpoint inside the home volume (which doesn't exist yet at bind time).
    for mount in config.extra_mounts:
        parts = mount.split(":", 2)
        container_path = parts[1] if len(parts) >= 2 else ""
        prefix = "/home/claude/"
        if container_path.startswith(prefix):
            rel = container_path[len(prefix):]
            parent = os.path.dirname(rel)
            if parent:
                os.makedirs(os.path.join(config.homedir, parent), exist_ok=True)

    project_root = config.git_root or os.getcwd()
    container_name = _container_name(project_root)

    container_cmd = resolve_container_cmd(cmd_args)
    cmd = [
        runtime,
        "run",
        "--rm",
        "--interactive",
        "--tty",
        "--init",
        "--name",
        container_name,
    ]
    # Docker Desktop translates bind-mount ownership to the container UID, so the
    # default `claude` (UID 1000) user works. Podman reports real ownership and
    # enforces permissions, so the handling depends on the engine mode, keeping a
    # non-root process in both cases:
    #   - rootless: the host user maps to container UID 0 by default, so a non-root
    #     UID can't own the mounts. keep-id remaps the host user to UID/GID 1000
    #     (the claude user) so ownership lines up.
    #   - rootful: keep-id is rootless-only (a no-op), but rootful can create
    #     idmapped mounts. Each host bind mount is idmapped so its owner -- this
    #     process's UID/GID, since claudebox2 runs on the host -- is presented
    #     inside the container as UID/GID 1000, i.e. the claude user. Reads/writes
    #     work and files written back keep the host owner. Requires virtiofs
    #     idmapped-mount support (Linux 6.12+, which current Podman Desktop ships).
    idmap_opt = ""
    if os.path.basename(runtime) == "podman":
        if podman_is_rootless(runtime):
            check_rootless_traversable(project_root)
            cmd += ["--userns=keep-id:uid=1000,gid=1000"]
        else:
            idmap_opt = f"idmap=uids={os.getuid()}-1000-1;gids={os.getgid()}-1000-1"
    cmd += [
        "--volume",
        _volume_opt(project_root, "/src", [idmap_opt]),
        "--volume",
        _volume_opt(f"{project_root}/.git", "/src/.git", ["ro", idmap_opt]),
        "--volume",
        _volume_opt(config.homedir, "/home/claude", [idmap_opt]),
        "--env",
        "ANTHROPIC_API_KEY",
        "--env",
        "ANTHROPIC_AUTH_TOKEN",
        "--env",
        "ANTHROPIC_BASE_URL",
        "--env",
        "TZ=America/Chicago",
    ]
    for var in config.extra_env:
        cmd += ["--env", var]
    for mount in config.extra_mounts:
        src, _, rest = mount.partition(":")
        dst, _, existing = rest.partition(":")
        opts = existing.split(",") if existing else []
        cmd += ["--volume", _volume_opt(src, dst, opts + [idmap_opt])]
    cmd += [config.tag] + container_cmd
    os.execvp(cmd[0], cmd)


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="claudebox2",
        description="Containerized Claude Code runner with per-project overrides.",
        epilog=(
            "User default: ~/.config/claudebox/Containerfile.default overrides the built-in image.\n"
            "\n"
            "Project configuration via .claudebox/ directory (at cwd or git root):\n"
            "  Containerfile       custom container image definition\n"
            "  build.sh            replaces the standard 'docker build' invocation\n"
            "  run.sh              replaces the standard 'docker run' invocation\n"
            "  tag.txt             override the image tag name\n"
            "  env                 env var names to pass through (one per line, # comments ok)\n"
            "  mounts              extra volume mounts: host:container[:opts], one per line;\n"
            "                      relative host paths resolve from the .claudebox parent dir"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    subparsers = parser.add_subparsers(dest="subcommand")
    build_parser = subparsers.add_parser("build", help="Build the container image")
    build_parser.add_argument(
        "-f", "--force", action="store_true", help="Force rebuild (passes --no-cache to the container runtime)"
    )
    run_parser = subparsers.add_parser(
        "run", help="Run a command in the container (default)"
    )
    run_parser.add_argument(
        "CMD",
        nargs="*",
        metavar="CMD",
        help="Command to run: 'claude' (default), 'codex', or arbitrary command+args",
    )
    subparsers.add_parser("statedir", help="Show the state directory for the current project")
    hash_parser = subparsers.add_parser("hash", help="Show the project hash for a directory")
    hash_parser.add_argument("dir", nargs="?", default=None, help="Directory to hash (default: cwd)")
    hash_parser.add_argument("--literal", action="store_true", help="Use the literal path string without resolving realpath")

    parser.add_argument(
        "-v",
        "--verbose",
        action="store_true",
        help="Print tag and home volume directory",
    )

    ns, remaining = parser.parse_known_args()
    subcommand: str = ns.subcommand or "run"

    if remaining and remaining[0] == "--":
        remaining = remaining[1:]

    if subcommand == "hash":
        directory = ns.dir if ns.dir is not None else os.getcwd()
        cmd_hash(directory, ns.literal)
        return

    # ns.CMD (run subparser positionals) + remaining (unrecognised flags) = full cmd.
    cmd_args = getattr(ns, "CMD", []) + remaining

    git_root = find_git_root()
    claudebox_dir = find_claudebox_dir()
    config = resolve_config(claudebox_dir, git_root)

    if subcommand == "statedir":
        cmd_statedir(config)
        return

    runtime = find_container_runtime()

    if ns.verbose:
        print(f"tag: {config.tag}")
        print(f"home: {config.homedir}")

    if subcommand == "build":
        build_image(config, runtime, cmd_args, force=getattr(ns, "force", False))
    else:
        cmd_run(config, runtime, cmd_args)


if __name__ == "__main__":
    main()
